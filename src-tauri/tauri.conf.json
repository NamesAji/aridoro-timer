{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aridoro Timer",
  "version": "1.0.0",
  "identifier": "com.aji.aridoro-timer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Aridoro Timer",
        "width": 256,
        "height": 256,
        "decorations": false,
        "transparent": true,
        "shadow": false, 
        "resizable": false
      }
  ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}